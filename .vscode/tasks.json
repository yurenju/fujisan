{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "serve fujisan",
      "type": "shell",
      "command": "python",
      "args": ["-m", "http.server", "8765"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "silent", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP",
          "endsPattern": "Serving HTTP"
        }
      }
    }
  ]
}
